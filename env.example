# Twilio Configuration (get these from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar (optional - for booking sync)
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service/account/key.json

# OpenAI API Key (optional - for advanced AI features)
OPENAI_API_KEY=your_openai_api_key

# Business Configuration
BUSINESS_NAME=Bayou Blades Lawn Care
BUSINESS_PHONE=+1234567890
BUSINESS_EMAIL=info@bayoublades.com
SERVICE_AREA=Houston, TX
PRIMARY_SERVICES=lawn care, landscaping, irrigation

# Notification Settings
OWNER_PHONE=+1234567890
OWNER_EMAIL=owner@bayoublades.com
NOTIFY_ON_HOT_LEADS=true
NOTIFY_ON_EMERGENCY=true